{
  "name": "detailed-weather-forecast",
  "version": "0.8.16",
  "packageManager": "yarn@4.12.0",
  "description": "Lovelace detailed-weather-forecast card",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "custom-cards"
  ],
  "type": "module",
  "module": "dist/detailedweatherforecast.js",
  "scripts": {
    "start": "rollup -c rollup.config.dev.js --watch",
    "build": "yarn clean && yarn lint && yarn rollup",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "rollup": "rollup -c",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@lit-labs/observers": "2.1.0",
    "custom-card-helpers": "2.0.0",
    "home-assistant-js-websocket": "9.6.0",
    "lightningcss": "^1.32.0",
    "lit": "^3.3.2",
    "memoize-one": "^6.0.0",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "rollup": "^4.60.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-css-only": "^4.5.5",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-plugin-serve": "^3.0.0",
    "rollup-plugin-string": "^3.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}

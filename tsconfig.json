{
  "compilerOptions": {
    "isolatedModules": true,
    "target": "es2017",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "lib": ["dom", "es2020"],
    "module": "es2020",
    "resolveJsonModule": true,
    "esModuleInterop": true
  }
}
